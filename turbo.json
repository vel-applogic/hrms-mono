{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "dependsOn": ["^build", "^db:client-generate"],
      "cache": false,
      "persistent": true
    },
    "dev:debug": {
      "dependsOn": ["^build", "^db:client-generate"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "db:client-generate": {
      "cache": false
    },
    "db:migrations-create": {
      "cache": false,
      "persistent": true
    },
    "db:migrations-apply": {
      "cache": false
    },
    "test:unit": {
      "dependsOn": ["^build"]
    }
  }
}
