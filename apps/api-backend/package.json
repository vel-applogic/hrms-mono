{
  "name": "api-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#src/*": "./dist/*"
  },
  "scripts": {
    "build": "nest build",
    "dev": "dotenv -e ../../.env -- nest start --watch",
    "dev:debug": "dotenv -e ../../.env -- nest start --debug 9601 --watch",
    "start:prod": "node dist/main.js",
    "db:migrations-apply": "dotenv -e ../../.env -- prisma migrate deploy --schema='./node_modules/@repo/db/prisma/schema.prisma' --config='./node_modules/@repo/db/prisma.config.ts'",
    "test:unit": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.980.0",
    "@aws-sdk/s3-request-presigner": "^3.980.0",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/schedule": "^6.1.1",
    "@repo/db": "workspace:*",
    "@repo/dto": "workspace:*",
    "@repo/nest-lib": "workspace:*",
    "@repo/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "handlebars": "^4.7.8",
    "joi": "^18.0.2",
    "nestjs-pino": "^4.5.0",
    "nodemailer": "^8.0.1",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "puppeteer-core": "^24.40.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@repo/config-eslint": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.1",
    "@types/nodemailer": "^7.0.11",
    "prisma": "^7.3.0",
    "typescript": "^5.9.3"
  }
}
