generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model AppMigration {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  createdAt DateTime @default(now())

  @@map("app_migrations")
}

enum AuditEntityTypeDbEnum {
  user
  user_admin
  candidate
  employee
  policy

  @@map("auditEntityTypeDbEnum")
}

model AuditActivity {
  id          Int                       @id @default(autoincrement())
  eventGroup  AuditEventGroupDbEnum     @map("event_group")
  eventType   AuditEventTypeDbEnum      @map("event_type")
  status      AuditActivityStatusDbEnum
  actorId     Int?                      @map("actor_id")
  description String?
  data        Json?
  createdAt   DateTime                  @default(now()) @map("created_at")
  actor       User?                     @relation(fields: [actorId], references: [id])
  entities    AuditActivityHasEntity[]

  @@index([eventGroup, eventType])
  @@index([actorId])
  @@index([createdAt])
  @@index([status])
  @@map("audit_activity")
}

model AuditActivityHasEntity {
  id             Int                   @id @default(autoincrement())
  auditId        Int                   @map("audit_id")
  entityType     AuditEntityTypeDbEnum @map("entity_type")
  entityId       Int                   @map("entity_id")
  message        String?
  isSourceEntity Boolean               @default(false) @map("is_source_entity")
  createdAt      DateTime              @default(now()) @map("created_at")
  audit          AuditActivity         @relation(fields: [auditId], references: [id])

  @@index([auditId])
  @@index([entityType, entityId])
  @@map("audit_activity_has_entity")
}

model Media {
  id           Int             @id @default(autoincrement())
  key          String
  thumbnailKey String?         @map("thumbnail_key")
  type         MediaTypeDbEnum
  name         String
  size         Int
  ext          String
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  candidateHasMedias    CandidateHasMedia[]
  policyHasMedias       PolicyHasMedia[]
  userEmployeeHasMedias UserEmployeeHasMedia[]
  leaveHasMedias        LeaveHasMedia[]

  @@map("media")
}

model User {
  id             Int            @id @default(autoincrement())
  email          String         @unique
  firstname      String
  lastname       String
  role           UserRoleDbEnum @default(user)
  plan           PlanEnum       @default(free)
  password       String
  isActive       Boolean        @default(true) @map("is_active")
  lastLoggedInAt DateTime?      @map("last_logged_in_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  userPlanHistory                UserPlanHistory[]
  auditActivities                AuditActivity[]
  userForgotPasswords            UserForgotPassword[]
  userVerifyEmails               UserVerifyEmail[]
  candidateHasFeedbacks          CandidateHasFeedback[]
  reportTo                       UserEmployeeDetail[]       @relation("EmployeeReportTo")
  employees                      UserEmployeeDetail[]       @relation("EmployeeUser")
  userEmployeeHasMedias          UserEmployeeHasMedia[]     @relation("EmployeeHasMediaUser")
  userEmployeeCompensations      UserEmployeeCompensation[] @relation("EmployeeCompensationUser")
  userEmployeeFeedbacksCreatedBy UserEmployeeFeedback[]     @relation("EmployeeFeedbackCreatedBy")
  userEmployeeFeedbacks          UserEmployeeFeedback[]     @relation("EmployeeFeedbackUser")
  leaves                         Leave[]

  @@map("users")
}

model UserForgotPassword {
  id                         Int       @id @default(autoincrement())
  userId                     Int       @map("user_id")
  forgotPasswordKey          String?   @map("forgot_password_key")
  forgotPasswordKeyCreatedAt DateTime  @default(now()) @map("forgot_password_key_created_at")
  resetAt                    DateTime? @map("reset_at")
  user                       User      @relation(fields: [userId], references: [id])

  @@map("user_forgot_password")
}

model UserVerifyEmail {
  id                      Int       @id @default(autoincrement())
  userId                  Int       @map("user_id")
  verifyEmailKey          String?   @map("verify_email_key")
  verifyEmailKeyCreatedAt DateTime  @default(now()) @map("verify_email_key_created_at")
  verifiedAt              DateTime? @map("verified_at")
  user                    User      @relation(fields: [userId], references: [id])

  @@map("user_verify_email")
}

model UserPlanHistory {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  plan      PlanEnum @map("plan")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_plan_history")
}

// EMPLOYEE

enum EmployeeStatusEnum {
  active
  resigned
  onLeave
  terminated

  @@map("employeeStatusEnum")
}

model UserEmployeeDetail {
  id            Int                @id @default(autoincrement())
  userId        Int                @unique @map("user_id")
  user          User               @relation("EmployeeUser", fields: [userId], references: [id])
  personalEmail String?            @map("personal_email")
  dob           DateTime
  pan           String             @unique
  aadhaar       String             @unique
  designation   String
  dateOfJoining DateTime           @map("date_of_joining")
  dateOfLeaving DateTime?          @map("date_of_leaving")
  status        EmployeeStatusEnum @map("status")
  reportToId    Int?               @map("report_to_id")
  reportTo      User?              @relation("EmployeeReportTo", fields: [reportToId], references: [id])
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@index([userId])
  @@index([reportToId])
  @@index([status])
  @@map("user_employee_detail")
}

enum EmployeeMediaType {
  photo
  resume
  offerLetter
  otherDocuments

  @@map("employeeMediaType")
}

model UserEmployeeHasMedia {
  id        Int               @id @default(autoincrement())
  userId    Int               @map("user_id")
  user      User              @relation("EmployeeHasMediaUser", fields: [userId], references: [id])
  mediaId   Int               @map("media_id")
  media     Media             @relation(fields: [mediaId], references: [id])
  type      EmployeeMediaType
  caption   String?           @map("caption")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@index([userId])
  @@map("employee_has_media")
}

model UserEmployeeCompensation {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  user            User      @relation("EmployeeCompensationUser", fields: [userId], references: [id])
  basic           Float     @map("basic")
  hra             Float
  otherAllowances Float     @map("other_allowances")
  gross           Float
  effectiveFrom   DateTime  @default(now()) @map("effective_from")
  effectiveTill   DateTime? @map("effective_till")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("employee_salary")
}

enum EmployeeFeedbackTrend {
  positive
  negative
  neutral

  @@map("employeeFeedbackTrend")
}

model UserEmployeeFeedback {
  id          Int                   @id @default(autoincrement())
  userId      Int                   @map("user_id")
  user        User                  @relation("EmployeeFeedbackUser", fields: [userId], references: [id])
  trend       EmployeeFeedbackTrend @map("trend")
  point       Int?                  @default(0) @map("point")
  title       String                @map("title")
  feedback    String                @map("feedback")
  createdById Int                   @map("created_by_id")
  createdBy   User                  @relation("EmployeeFeedbackCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_employee_feedback")
}

// LEAVES

enum LeaveTypeEnum {
  casual
  sick
  medical
  earned

  @@map("leaveTypeEnum")
}

enum LeaveStatusEnum {
  pending
  approved
  rejected
  cancelled

  @@map("leaveStatusEnum")
}

model LeaveConfig {
  id              Int      @id @default(autoincrement())
  maxLeaves       Int      @map("max_leaves")
  maxSickLeaves   Int      @map("max_sick_leaves")
  maxEarnedLeaves Int      @map("max_earned_leaves")
  maxCasualLeaves Int      @map("max_casual_leaves")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("leave_config")
}

model Leave {
  id             Int             @id @default(autoincrement())
  userId         Int             @map("user_id")
  user           User            @relation(fields: [userId], references: [id])
  leaveType      LeaveTypeEnum   @map("leave_type")
  startDate      DateTime        @map("start_date")
  endDate        DateTime        @map("end_date")
  numberOfDays   Int             @map("number_of_days")
  reason         String          @map("reason")
  status         LeaveStatusEnum @default(pending) @map("status")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  leaveHasMedias LeaveHasMedia[]

  @@index([userId])
  @@map("leave")
}

model LeaveHasMedia {
  id        Int      @id @default(autoincrement())
  leaveId   Int      @map("leave_id")
  leave     Leave    @relation(fields: [leaveId], references: [id])
  mediaId   Int      @map("media_id")
  media     Media    @relation(fields: [mediaId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([leaveId])
  @@index([mediaId])
  @@map("leave_has_media")
}

// CANDIDATE
enum CandidateSource {
  email
  googleSearch
  lead
  linkedin
  referral
  websiteForm

  @@map("candidateSource")
}

enum NoticePeriodUnit {
  days
  weeks
  months

  @@map("noticePeriodUnit")
}

enum CandidateStatus {
  new
  planed
  notReachable
  selected
  onHold
  rejected
}

enum CandidateProgress {
  new
  infoCollected
  lev1InterviewScheduled
  lev1InterviewCompleted
  lev2InterviewScheduled
  lev2InterviewCompleted
  offerReleased
  offerAccepted
}

enum CandidateMediaType {
  resume
  offerLetter
  otherDocuments

  @@map("candidateMediaType")
}

model CandidateHasMedia {
  id          Int                @id @default(autoincrement())
  candidateId Int                @map("candidate_id")
  mediaId     Int                @map("media_id")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  type        CandidateMediaType @map("type")
  media       Media              @relation(fields: [mediaId], references: [id])
  candidate   Candidate          @relation(fields: [candidateId], references: [id])
}

model Candidate {
  id                 Int               @id @default(autoincrement())
  firstname          String
  lastname           String
  email              String
  contactNumbers     String[]
  source             CandidateSource
  urls               String[]
  expInYears         Float
  relevantExpInYears Float
  skills             String[]
  currentCtcInLacs   Float
  expectedCtcInLacs  Float
  noticePeriod       Float
  noticePeriodUnit   NoticePeriodUnit
  status             CandidateStatus   @default(new)
  progress           CandidateProgress @default(new)

  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  isDeleted             Boolean                @default(false) @map("is_deleted")
  candidateHasMedias    CandidateHasMedia[]
  candidateHasFeedbacks CandidateHasFeedback[]

  @@map("candidate")
}

model CandidateHasFeedback {
  id          Int       @id @default(autoincrement())
  candidateId Int       @map("candidate_id")
  createdById Int       @map("created_by_id")
  feedback    String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  createdBy   User      @relation(fields: [createdById], references: [id])

  @@index([candidateId])
  @@map("candidate_has_feedback")
}

// POLICIES
model Policy {
  id        Int      @id @default(autoincrement())
  title     String
  content   Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  policyHasMedias PolicyHasMedia[]

  @@map("policy")
}

model PolicyHasMedia {
  id        Int      @id @default(autoincrement())
  policyId  Int      @map("policy_id")
  policy    Policy   @relation(fields: [policyId], references: [id])
  mediaId   Int      @map("media_id")
  media     Media    @relation(fields: [mediaId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("policy_has_media")
}

// ENUMS

enum UserRoleDbEnum {
  admin
  user

  @@map("userRoleDbEnum")
}

enum PlanEnum {
  free
  premium
}

enum MediaTypeDbEnum {
  doc
  image
  zip
  video

  @@map("mediaTypeDbEnum")
}

enum AuditEventGroupDbEnum {
  authentication
  operation

  @@map("auditEventGroupDbEnum")
}

enum AuditEventTypeDbEnum {
  login_success
  login_failure
  create
  update
  delete
  password_reset
  password_reset_request
  otp_request
  register
  email_verify
  account_activate
  confirm
  upgrade_plan
  downgrade_plan
  block_user
  unblock_user

  @@map("auditEventTypeDbEnum")
}

enum AuditActivityStatusDbEnum {
  success
  failure

  @@map("auditActivityStatusDbEnum")
}
