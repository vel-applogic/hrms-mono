// DEVICE

enum DeviceType {
  mobile
  tablet
  laptop
  cpu
  keyboard
  mouse
  headphone
  other
}

enum DeviceStatus {
  good
  physicallyDamaged
  notWorking
  lost
  stolen
}

model Device {
  id                  Int                       @id @default(autoincrement())
  organizationId      Int                       @map("organization_id")
  organization        Organization              @relation(fields: [organizationId], references: [id])
  type                DeviceType                @map("type")
  brand               String                    @map("brand")
  model               String                    @map("model")
  serialNumber        String                    @map("serial_number")
  price               Float                     @map("price")
  purchasedAt         DateTime?                 @map("purchased_at") @db.Date
  warrantyExpiresAt   DateTime                  @map("warranty_expires_at") @db.Date
  inWarranty          Boolean                   @default(true) @map("in_warranty")
  status              DeviceStatus              @map("status")
  config              String?                   @map("config")
  assignedToId        Int?                      @map("assigned_to_id")
  assignedTo          User?                     @relation("DeviceAssignedTo", fields: [assignedToId], references: [id])
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  deviceHasMedias     DeviceHasMedia[]
  possessionHistories DevicePossessionHistory[]

  @@map("device")
}

model DeviceHasMedia {
  id       Int     @id @default(autoincrement())
  deviceId Int     @map("device_id")
  device   Device  @relation(fields: [deviceId], references: [id])
  mediaId  Int     @map("media_id")
  media    Media   @relation(fields: [mediaId], references: [id])
  caption  String? @map("caption")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("device_has_media")
}

// AUDIT

enum AuditEntityTypeDbEnum {
  user
  user_admin
  candidate
  employee
  policy
  device

  @@map("auditEntityTypeDbEnum")
}

model AuditActivity {
  id          Int                       @id @default(autoincrement())
  eventGroup  AuditEventGroupDbEnum     @map("event_group")
  eventType   AuditEventTypeDbEnum      @map("event_type")
  status      AuditActivityStatusDbEnum
  actorId     Int?                      @map("actor_id")
  description String?
  data        Json?
  createdAt   DateTime                  @default(now()) @map("created_at")
  actor       User?                     @relation(fields: [actorId], references: [id])
  entities    AuditActivityHasEntity[]

  @@index([eventGroup, eventType])
  @@index([actorId])
  @@index([createdAt])
  @@index([status])
  @@map("audit_activity")
}

model AuditActivityHasEntity {
  id             Int                   @id @default(autoincrement())
  auditId        Int                   @map("audit_id")
  entityType     AuditEntityTypeDbEnum @map("entity_type")
  entityId       Int                   @map("entity_id")
  message        String?
  isSourceEntity Boolean               @default(false) @map("is_source_entity")
  createdAt      DateTime              @default(now()) @map("created_at")
  audit          AuditActivity         @relation(fields: [auditId], references: [id])

  @@index([auditId])
  @@index([entityType, entityId])
  @@map("audit_activity_has_entity")
}

// APP MIGRATIONS

model AppMigration {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  createdAt DateTime @default(now())

  @@map("app_migrations")
}

// EXPENSE
model Expense {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  date           DateTime     @map("date") @db.Date
  description    String?      @map("description")
  type           ExpenseType  @map("type")
  amount         Float        @map("amount")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("expense")
}

model ExpenseForecast {
  id             Int                      @id @default(autoincrement())
  organizationId Int                      @map("organization_id")
  organization   Organization             @relation(fields: [organizationId], references: [id])
  description    String?                  @map("description")
  type           ExpenseType              @map("type")
  amount         Float                    @map("amount")
  frequency      ExpenseForecastFrequency @map("frequency")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("expense_forecast")
}

// REIMBURSEMENT

enum ReimbursementStatusDbEnum {
  pending
  approved
  paid
  rejected

  @@map("reimbursementStatusDbEnum")
}

model Reimbursement {
  id             Int                       @id @default(autoincrement())
  organizationId Int                       @map("organization_id")
  organization   Organization              @relation(fields: [organizationId], references: [id])
  userId         Int                       @map("user_id")
  user           User                      @relation(fields: [userId], references: [id])
  title          String
  amount         Float
  status         ReimbursementStatusDbEnum @default(pending)
  rejectReason   String?                   @map("reject_reason")
  approvedAt     DateTime?                 @map("approved_at")
  paidAt         DateTime?                 @map("paid_at")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  reimbursementHasMedias    ReimbursementHasMedia[]
  reimbursementHasFeedbacks ReimbursementHasFeedback[]

  @@index([organizationId])
  @@index([userId])
  @@map("reimbursement")
}

model ReimbursementHasMedia {
  id              Int           @id @default(autoincrement())
  reimbursementId Int           @map("reimbursement_id")
  reimbursement   Reimbursement @relation(fields: [reimbursementId], references: [id])
  mediaId         Int           @map("media_id")
  media           Media         @relation(fields: [mediaId], references: [id])
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([reimbursementId])
  @@index([mediaId])
  @@map("reimbursement_has_media")
}

model ReimbursementHasFeedback {
  id              Int           @id @default(autoincrement())
  reimbursementId Int           @map("reimbursement_id")
  reimbursement   Reimbursement @relation(fields: [reimbursementId], references: [id])
  createdById     Int           @map("created_by_id")
  createdBy       User          @relation(fields: [createdById], references: [id])
  message         String
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([reimbursementId])
  @@map("reimbursement_has_feedback")
}

