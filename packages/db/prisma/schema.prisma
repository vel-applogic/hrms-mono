generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

// MEDIA
model Media {
  id             Int             @id @default(autoincrement())
  organizationId Int             @map("organization_id")
  organization   Organization    @relation(fields: [organizationId], references: [id])
  key            String
  thumbnailKey   String?         @map("thumbnail_key")
  type           MediaTypeDbEnum
  name           String
  size           Int
  ext            String
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  candidateHasMedias          CandidateHasMedia[]
  policyHasMedias             PolicyHasMedia[]
  employeeHasMedias           EmployeeHasMedia[]
  leaveHasMedias              LeaveHasMedia[]
  organizationLogos           Organization[]               @relation("OrganizationLogo")
  organizationHasDocuments    OrganizationHasDocument[]
  employyBgvFeedbackHasMedias employyBgvFeedbackHasMedia[]
  deviceHasMedias             DeviceHasMedia[]
  reimbursementHasMedias      ReimbursementHasMedia[]

  @@map("media")
}

// CURRENCY
model Currency {
  id            Int            @id @default(autoincrement())
  code          String         @unique
  name          String
  symbol        String?
  organizations Organization[]

  @@map("currency")
}

// COUNTRY

model Country {
  id        Int       @id @default(autoincrement())
  name      String
  code      String    @unique
  addresses Address[]

  @@map("country")
}

// ADDRESS
model Address {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  countryId      Int          @map("country_id")
  country        Country      @relation(fields: [countryId], references: [id])
  addressLine1   String       @map("address_line_1")
  addressLine2   String       @map("address_line_2")
  city           String       @map("city")
  state          String       @map("state")
  postalCode     String       @map("postal_code")
  latitude       Float?       @map("latitude")
  longitude      Float?       @map("longitude")

  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")
  organizationHasAddresses OrganizationHasAddress[]

  @@map("address")
}

// CONTACT

enum ContactType {
  phone
  email
  website
  socialMediaLink
}

model Contact {
  id                      Int                      @id @default(autoincrement())
  organizationId          Int                      @map("organization_id")
  organization            Organization             @relation(fields: [organizationId], references: [id])
  contact                 String                   @map("contact_number")
  contactType             ContactType              @map("contact_type")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  organizationHasContacts OrganizationHasContact[]

  @@map("contact")
}

// USER

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  firstname      String
  lastname       String
  password       String
  isSuperAdmin   Boolean   @default(false) @map("is_super_admin")
  isActive       Boolean   @default(true) @map("is_active")
  lastLoggedInAt DateTime? @map("last_logged_in_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  auditActivities                 AuditActivity[]
  userForgotPasswords             UserForgotPassword[]
  userVerifyEmails                UserVerifyEmail[]
  userInvites                     UserInvite[]               @relation("UserInviteUser")
  sentInvites                     UserInvite[]               @relation("UserInviteInvitedBy")
  candidateHasFeedbacks           CandidateHasFeedback[]
  reportTo                        Employee[]                 @relation("EmployeeReportTo")
  employees                       Employee[]                 @relation("EmployeeUser")
  employeeHasMedias               EmployeeHasMedia[]         @relation("EmployeeHasMediaUser")
  payrollCompensations            PayrollCompensation[]      @relation("EmployeeCompensationUser")
  employeeFeedbacksCreatedBy      EmployeeFeedback[]         @relation("EmployeeFeedbackCreatedBy")
  employeeFeedbacks               EmployeeFeedback[]         @relation("EmployeeFeedbackUser")
  leaves                          Leave[]
  employeeLeaveCounters           EmployeeLeaveCounter[]
  payrollDeductions               PayrollDeduction[]
  payrollPayslips                 PayrollPayslip[]
  organizationHasUsers            OrganizationHasUser[]
  userInBranches                  UserInBranch[]
  employeeBgvFeedbacks            employeeBgvFeedback[]      @relation("EmployeeBgvFeedbackUser")
  assignedDevices                 Device[]                   @relation("DeviceAssignedTo")
  devicePossessionHistories       DevicePossessionHistory[]
  reimbursements                  Reimbursement[]
  reimbursementFeedbacksCreatedBy ReimbursementHasFeedback[]

  @@map("users")
}

model UserForgotPassword {
  id                         Int       @id @default(autoincrement())
  userId                     Int       @map("user_id")
  user                       User      @relation(fields: [userId], references: [id])
  forgotPasswordKey          String?   @map("forgot_password_key")
  forgotPasswordKeyCreatedAt DateTime  @default(now()) @map("forgot_password_key_created_at")
  resetAt                    DateTime? @map("reset_at")

  @@map("user_forgot_password")
}

model UserVerifyEmail {
  id                      Int       @id @default(autoincrement())
  userId                  Int       @map("user_id")
  user                    User      @relation(fields: [userId], references: [id])
  verifyEmailKey          String?   @map("verify_email_key")
  verifyEmailKeyCreatedAt DateTime  @default(now()) @map("verify_email_key_created_at")
  verifiedAt              DateTime? @map("verified_at")

  @@map("user_verify_email")
}

model UserInBranch {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  user           User         @relation(fields: [userId], references: [id])
  branchId       Int          @map("branch_id")
  branch         Branch       @relation(fields: [branchId], references: [id])
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, branchId])
}

model UserInvite {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  user           User         @relation("UserInviteUser", fields: [userId], references: [id])
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  inviteKey      String       @map("invite_key")
  invitedById    Int          @map("invited_by_id")
  invitedBy      User         @relation("UserInviteInvitedBy", fields: [invitedById], references: [id])
  acceptedAt     DateTime?    @map("accepted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([userId])
  @@index([organizationId])
  @@map("user_invite")
}

model DevicePossessionHistory {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         Int          @map("user_id")
  user           User         @relation(fields: [userId], references: [id])
  deviceId       Int          @map("device_id")
  device         Device       @relation(fields: [deviceId], references: [id])
  fromDate       DateTime     @map("from_date")
  toDate         DateTime?    @map("to_date")
  notes          String[]     @map("notes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([deviceId])
  @@index([organizationId])
  @@map("device_possession_history")
}

// ORGANIZATION
model Organization {
  id         Int      @id @default(autoincrement())
  name       String
  logoId     Int?     @map("logo_id")
  logo       Media?   @relation("OrganizationLogo", fields: [logoId], references: [id])
  website    String?  @map("website")
  currencyId Int      @map("currency_id")
  currency   Currency @relation(fields: [currencyId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizationHasUsers      OrganizationHasUser[]
  branches                  Branch[]
  userInBranches            UserInBranch[]
  userInvites               UserInvite[]
  employees                 Employee[]
  payrollCompensations      PayrollCompensation[]
  payrollDeductions         PayrollDeduction[]
  payrollPayslips           PayrollPayslip[]
  employeeFeedbacks         EmployeeFeedback[]
  employeeLeaveCounters     EmployeeLeaveCounter[]
  leaves                    Leave[]
  candidates                Candidate[]
  policies                  Policy[]
  medias                    Media[]
  settings                  OrganizationSetting[]
  organizationHasDocuments  OrganizationHasDocument[]
  employeeBgvFeedbacks      employeeBgvFeedback[]
  addresses                 Address[]
  contacts                  Contact[]
  organizationHasContacts   OrganizationHasContact[]
  organizationHasAddresses  OrganizationHasAddress[]
  holidays                  Holiday[]
  devices                   Device[]
  devicePossessionHistories DevicePossessionHistory[]
  expenses                  Expense[]
  expenseForecasts          ExpenseForecast[]
  reimbursements            Reimbursement[]

  @@map("organization")
}

model OrganizationHasContact {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  contactId      Int          @map("contact_id")
  contact        Contact      @relation(fields: [contactId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, contactId])
  @@map("organization_has_contact")
}

model OrganizationHasAddress {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  addressId      Int          @map("address_id")
  address        Address      @relation(fields: [addressId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, addressId])
  @@map("organization_has_address")
}

model OrganizationHasUser {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         Int          @map("user_id")
  user           User         @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles UserRoleDbEnum[]

  @@unique([organizationId, userId])
  @@map("organization_has_user")
}

enum NoOfDaysInMonthDbEnum {
  dynamic
  thirty
  thirtyOne
}

model OrganizationSetting {
  id                   Int                   @id @default(autoincrement())
  organizationId       Int                   @map("organization_id")
  organization         Organization          @relation(fields: [organizationId], references: [id])
  noOfDaysInMonth      NoOfDaysInMonthDbEnum @default(thirty) @map("no_of_days_in_month")
  totalLeaveInDays     Int                   @default(24) @map("total_leave_in_days")
  sickLeaveInDays      Int                   @default(10) @map("sick_leave_in_days")
  earnedLeaveInDays    Int                   @default(10) @map("earned_leave_in_days")
  casualLeaveInDays    Int                   @default(10) @map("casual_leave_in_days")
  maternityLeaveInDays Int                   @default(10) @map("maternity_leave_in_days")
  paternityLeaveInDays Int                   @default(10) @map("paternity_leave_in_days")
  weeklyOffDays        Int[]                 @default([0, 6]) @map("weekly_off_days")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("organization_settings")
}

model OrganizationHasDocument {
  id             Int             @id @default(autoincrement())
  organizationId Int             @map("organization_id")
  organization   Organization    @relation(fields: [organizationId], references: [id])
  documentId     Int             @map("document_id")
  document       Media           @relation(fields: [documentId], references: [id])
  mediaType      MediaTypeDbEnum @map("media_type")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("organization_has_document")
}

// BRANCH
model Branch {
  id             Int          @id @default(autoincrement())
  name           String
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userInBranches UserInBranch[]

  @@map("branche")
}

// EMPLOYEE

model Employee {
  id             Int                @id @default(autoincrement())
  userId         Int                @map("user_id")
  user           User               @relation("EmployeeUser", fields: [userId], references: [id])
  organizationId Int                @map("organization_id")
  organization   Organization       @relation(fields: [organizationId], references: [id])
  employeeCode   String             @map("employee_code")
  personalEmail  String?            @map("personal_email")
  dob            DateTime
  pan            String?
  aadhaar        String?
  designation    String
  dateOfJoining  DateTime           @map("date_of_joining")
  dateOfLeaving  DateTime?          @map("date_of_leaving")
  status         EmployeeStatusEnum @map("status")
  reportToId     Int?               @map("report_to_id")
  reportTo       User?              @relation("EmployeeReportTo", fields: [reportToId], references: [id])
  isBgVerified   Boolean            @default(false) @map("is_bg_verified")
  candidateId    Int?               @map("candidate_id")
  candidate      Candidate?         @relation("EmployeeCandidate", fields: [candidateId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  candidatesConverted Candidate[] @relation("CandidateEmployee")

  @@unique([userId, organizationId])
  @@unique([employeeCode, organizationId])
  @@unique([pan, organizationId])
  @@unique([aadhaar, organizationId])
  @@index([userId])
  @@index([reportToId])
  @@index([status])
  @@map("user_employee_detail")
}

model employeeBgvFeedback {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  user           User         @relation("EmployeeBgvFeedbackUser", fields: [userId], references: [id])
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  feedback       String       @map("feedback")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employyBgvFeedbackHasMedias employyBgvFeedbackHasMedia[]

  @@index([userId])
  @@map("employee_bgv_feedback")
}

model employyBgvFeedbackHasMedia {
  id                    Int                 @id @default(autoincrement())
  employeeBgvFeedbackId Int                 @map("employee_bgv_feedback_id")
  employeeBgvFeedback   employeeBgvFeedback @relation(fields: [employeeBgvFeedbackId], references: [id])
  mediaId               Int                 @map("media_id")
  media                 Media               @relation(fields: [mediaId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([employeeBgvFeedbackId])
  @@index([mediaId])
  @@map("employee_bgv_feedback_has_media")
}

model EmployeeHasMedia {
  id      Int               @id @default(autoincrement())
  userId  Int               @map("user_id")
  user    User              @relation("EmployeeHasMediaUser", fields: [userId], references: [id])
  mediaId Int               @map("media_id")
  media   Media             @relation(fields: [mediaId], references: [id])
  type    EmployeeMediaType
  caption String?           @map("caption")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("employee_has_media")
}

model PayrollCompensation {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  user           User         @relation("EmployeeCompensationUser", fields: [userId], references: [id])
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  grossAmount    Float        @map("gross_amount")
  effectiveFrom  DateTime     @map("effective_from") @db.Date
  effectiveTill  DateTime?    @map("effective_till") @db.Date
  isActive       Boolean      @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payrollCompensationLineItems PayrollCompensationLineItem[]

  @@index([userId])
  @@map("employee_compensation")
}

model PayrollCompensationLineItem {
  id                    Int                 @id @default(autoincrement())
  payrollCompensationId Int                 @map("payroll_compensation_id")
  payrollCompensation   PayrollCompensation @relation(fields: [payrollCompensationId], references: [id])
  title                 String              @map("title")
  amount                Float               @map("amount")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@map("payroll_compensation_line_item")
}

model PayrollDeduction {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  user           User         @relation(fields: [userId], references: [id])
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  effectiveFrom  DateTime     @map("effective_from") @db.Date
  effectiveTill  DateTime?    @map("effective_till") @db.Date
  isActive       Boolean      @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payrollDeductionLineItems PayrollDeductionLineItem[]

  @@index([userId])
  @@map("user_employee_deduction")
}

model PayrollDeductionLineItem {
  id                 Int                       @id @default(autoincrement())
  payrollDeductionId Int                       @map("payroll_deduction_id")
  payrollDeduction   PayrollDeduction          @relation(fields: [payrollDeductionId], references: [id])
  type               PayrollDeductionType      @map("type")
  frequency          PayrollDeductionFrequency @map("frequency")
  amount             Float                     @map("amount")
  otherTitle         String?                   @map("other_title")
  specificMonth      DateTime?                 @map("specific_month") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([payrollDeductionId, type, frequency])
  @@map("payroll_deduction_line_item")
}

model EmployeeFeedback {
  id             Int                   @id @default(autoincrement())
  userId         Int                   @map("user_id")
  user           User                  @relation("EmployeeFeedbackUser", fields: [userId], references: [id])
  organizationId Int                   @map("organization_id")
  organization   Organization          @relation(fields: [organizationId], references: [id])
  trend          EmployeeFeedbackTrend @map("trend")
  point          Int?                  @default(0) @map("point")
  title          String                @map("title")
  feedback       String                @map("feedback")
  createdById    Int                   @map("created_by_id")
  createdBy      User                  @relation("EmployeeFeedbackCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_employee_feedback")
}

model EmployeeLeaveCounter {
  id                   Int          @id @default(autoincrement())
  userId               Int          @map("user_id")
  user                 User         @relation(fields: [userId], references: [id])
  organizationId       Int          @map("organization_id")
  organization         Organization @relation(fields: [organizationId], references: [id])
  casualLeaves         Float        @map("casual_leaves")
  sickLeaves           Float        @map("sick_leaves")
  earnedLeaves         Float        @map("earned_leaves")
  totalLeavesUsed      Float        @map("total_leaves_used")
  totalLeavesAvailable Float        @map("total_leaves_available")
  financialYear        String       @map("financial_year")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  @@unique([userId, organizationId, financialYear])
  @@index([userId, organizationId])
  @@map("user_employee_leave_counter")
}

// PAYROLL
model PayrollPayslip {
  id                      Int                      @id @default(autoincrement())
  userId                  Int                      @map("user_id")
  user                    User                     @relation(fields: [userId], references: [id])
  organizationId          Int                      @map("organization_id")
  organization            Organization             @relation(fields: [organizationId], references: [id])
  month                   Int                      @map("month")
  year                    Int                      @map("year")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  grossAmount             Int                      @map("gross_amount")
  netAmount               Int                      @map("net_amount")
  deductionAmount         Int                      @map("deduction_amount")
  pdfS3Key                String                   @map("pdf_s3_key")
  payrollPayslipLineItems PayrollPayslipLineItem[]

  @@unique([userId, month, year])
  @@index([userId])
  @@map("payslip")
}

model PayrollPayslipLineItem {
  id          Int                        @id @default(autoincrement())
  payslipId   Int                        @map("payslip_id")
  payslip     PayrollPayslip             @relation(fields: [payslipId], references: [id])
  type        PayrollPayslipLineItemType @map("type")
  amount      Int                        @map("amount")
  title       String                     @map("title")
  description String?                    @map("description")
  createdAt   DateTime                   @default(now()) @map("created_at")
  updatedAt   DateTime                   @updatedAt @map("updated_at")

  @@index([payslipId])
  @@map("payslip_line_item")
}

// LEAVES
model Leave {
  id              Int              @id @default(autoincrement())
  userId          Int              @map("user_id")
  user            User             @relation(fields: [userId], references: [id])
  organizationId  Int              @map("organization_id")
  organization    Organization     @relation(fields: [organizationId], references: [id])
  leaveType       LeaveTypeEnum    @map("leave_type")
  startDate       DateTime         @map("start_date") @db.Date
  endDate         DateTime         @map("end_date") @db.Date
  startDuration   LeaveDayHalfEnum @default(full) @map("start_duration")
  endDuration     LeaveDayHalfEnum @default(full) @map("end_duration")
  numberOfDays    Float            @map("number_of_days")
  numberOfLopDays Float            @default(0) @map("number_of_lop_days")
  isConsumed      Boolean          @default(false) @map("is_consumed")
  reason          String           @map("reason")
  status          LeaveStatusEnum  @default(pending) @map("status")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  leaveHasMedias  LeaveHasMedia[]

  @@index([userId])
  @@map("leave")
}

model LeaveHasMedia {
  id        Int      @id @default(autoincrement())
  leaveId   Int      @map("leave_id")
  leave     Leave    @relation(fields: [leaveId], references: [id])
  mediaId   Int      @map("media_id")
  media     Media    @relation(fields: [mediaId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([leaveId])
  @@index([mediaId])
  @@map("leave_has_media")
}

// CANDIDATE

model CandidateHasMedia {
  id          Int                @id @default(autoincrement())
  candidateId Int                @map("candidate_id")
  mediaId     Int                @map("media_id")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  type        CandidateMediaType @map("type")
  media       Media              @relation(fields: [mediaId], references: [id])
  candidate   Candidate          @relation(fields: [candidateId], references: [id])
}

model Candidate {
  id                 Int               @id @default(autoincrement())
  organizationId     Int               @map("organization_id")
  organization       Organization      @relation(fields: [organizationId], references: [id])
  firstname          String
  lastname           String
  email              String
  contactNumbers     String[]
  source             CandidateSource
  urls               String[]
  expInYears         Float
  relevantExpInYears Float
  skills             String[]
  currentCtcInLacs   Float
  expectedCtcInLacs  Float
  noticePeriod       Float
  noticePeriodUnit   NoticePeriodUnit
  status             CandidateStatus   @default(new)
  progress           CandidateProgress @default(new)
  dob                DateTime?
  pan                String?
  aadhaar            String?
  employeeId         Int?              @map("employee_id")
  employee           Employee?         @relation("CandidateEmployee", fields: [employeeId], references: [id])
  employeeSource     Employee[]        @relation("EmployeeCandidate")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  isDeleted             Boolean                @default(false) @map("is_deleted")
  candidateHasMedias    CandidateHasMedia[]
  candidateHasFeedbacks CandidateHasFeedback[]

  @@unique([email, organizationId])
  @@index([organizationId])
  @@map("candidate")
}

model CandidateHasFeedback {
  id          Int       @id @default(autoincrement())
  candidateId Int       @map("candidate_id")
  createdById Int       @map("created_by_id")
  feedback    String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  createdBy   User      @relation(fields: [createdById], references: [id])

  @@index([candidateId])
  @@map("candidate_has_feedback")
}

// POLICIES
model Policy {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  title          String
  content        Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  policyHasMedias PolicyHasMedia[]

  @@map("policy")
}

model PolicyHasMedia {
  id       Int    @id @default(autoincrement())
  policyId Int    @map("policy_id")
  policy   Policy @relation(fields: [policyId], references: [id])
  mediaId  Int    @map("media_id")
  media    Media  @relation(fields: [mediaId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("policy_has_media")
}

